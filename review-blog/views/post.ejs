<%- include('partials/header') %>

<header class="page-head">
  <p class="eyebrow">Contribute</p>
  <h1 class="page-title">Post a Review</h1>
  <p class="page-sub">Add a new entry to the ledger.</p>
</header>

<form class="post-form" method="POST" action="/post">
  <div class="field">
    <label for="title">Title</label>
    <input type="text" id="title" name="title" required
           placeholder="What are you reviewing?">
  </div>

  <div class="field-row">
    <div class="field">
      <label for="category">Category</label>
      <select id="category" name="category">
        <% Object.entries(categories).forEach(([slug, label]) => { %>
          <option value="<%= slug %>"><%= label %></option>
        <% }) %>
      </select>
    </div>

    <div class="field">
      <label for="rating">Rating</label>
      <select id="rating" name="rating">
        <option value="5">★★★★★ — 5</option>
        <option value="4.5">★★★★½ — 4.5</option>
        <option value="4" selected>★★★★ — 4</option>
        <option value="3.5">★★★½ — 3.5</option>
        <option value="3">★★★ — 3</option>
        <option value="2.5">★★½ — 2.5</option>
        <option value="2">★★ — 2</option>
        <option value="1.5">★½ — 1.5</option>
        <option value="1">★ — 1</option>
        <option value="0.5">½ — 0.5</option>
        <option value="0">— 0</option>
      </select>
    </div>
  </div>

  <div class="field">
    <label for="excerpt">Excerpt <span class="label-hint">(one or two sentences for the card)</span></label>
    <textarea id="excerpt" name="excerpt" rows="2" maxlength="220"
              placeholder="Leave blank to auto-generate from the review."></textarea>
  </div>

  <div class="field">
    <label for="body">Review</label>
    <textarea id="body" name="body" rows="10" required
              placeholder="Separate paragraphs with a blank line."></textarea>
  </div>

  <div class="field">
    <label for="image">Cover image URL <span class="label-hint">(optional)</span></label>
    <input type="url" id="image" name="image"
           placeholder="Leave blank for the ghost letter.">
  </div>

  <button type="submit" class="btn">Publish review</button>
  <p class="form-note">Posts are kept in memory for now — they reset when the
    server restarts. Wiring up a database is a good next step.</p>
</form>

<%- include('partials/footer') %>

<%# Admin: write a new review. This replaced the old /post page.
    NOTE the include paths — this file lives in views/admin/, so
    partials are one directory up. %>
<%- include('../partials/header') %>

<header class="page-head admin-head">
  <div>
    <p class="eyebrow">Admin</p>
    <h1 class="page-title">Write a Review</h1>
    <p class="page-sub">Add a new entry to the ledger.</p>
  </div>
  <a class="btn btn--ghost" href="/admin/reviews">Manage reviews →</a>
</header>

<% if (error) { %>
  <p class="form-error" role="alert"><%= error %></p>
<% } %>

<form class="post-form" method="POST" action="/admin">
  <div class="field">
    <label for="title">Title</label>
    <input type="text" id="title" name="title" required
           value="<%= values.title || '' %>"
           placeholder="What are you reviewing?">
  </div>

  <div class="field-row">
    <div class="field">
      <label for="category">Category</label>
      <select id="category" name="category">
        <% Object.entries(categories).forEach(([slug, label]) => { %>
          <option value="<%= slug %>" <%= values.category === slug ? 'selected' : '' %>><%= label %></option>
        <% }) %>
      </select>
    </div>

    <div class="field">
      <label for="rating">Rating</label>
      <select id="rating" name="rating">
        <%# Whole stars only, 5 down to 1. %>
        <% const chosen = values.rating !== undefined ? String(values.rating) : '4'; %>
        <% [5, 4, 3, 2, 1].forEach((v) => { %>
          <option value="<%= v %>" <%= String(v) === chosen ? 'selected' : '' %>>
            <%= '★'.repeat(v) %> — <%= v %>
          </option>
        <% }) %>
      </select>
    </div>
  </div>

  <div class="field">
    <label for="excerpt">Excerpt <span class="label-hint">(one or two sentences for the card)</span></label>
    <textarea id="excerpt" name="excerpt" rows="2" maxlength="220"
              placeholder="Leave blank to auto-generate from the review."><%= values.excerpt || '' %></textarea>
  </div>

  <div class="field">
    <label for="body">Review</label>
    <textarea id="body" name="body" rows="10" required
              placeholder="Separate paragraphs with a blank line."><%= values.body || '' %></textarea>
  </div>

  <div class="field">
    <label for="image">Cover image URL <span class="label-hint">(optional)</span></label>
    <input type="url" id="image" name="image"
           value="<%= values.image || '' %>"
           placeholder="Leave blank for the ghost letter.">
  </div>

  <button type="submit" class="btn">Publish review</button>
  <p class="form-note">Published reviews are stored in <code>reviews.db</code>
    and survive restarts. Delete that file to reset to the sample content.</p>
</form>

<%- include('../partials/footer') %>
